classDiagram
  direction TB

  %% ============================================================
  %% ENUMS
  %% ============================================================
  class Direccion {
    <<enumeration>>
    ARRIBA
    ABAJO
    IZQUIERDA
    DERECHA
    -int deltaFila
    -int deltaColumna
    +getDeltaFila() int
    +getDeltaColumna() int
  }

  %% ============================================================
  %% MODELO CORE
  %% ============================================================
  class Posicion {
    -int fila
    -int columna
    +getFila() int
    +getColumna() int
    +trasladar(Direccion d) Posicion
    +equals(Object o) boolean
    +hashCode() int
  }

  class Estadisticas {
    -int movimientos
    -int empujes
    -int usosUndo
    +registrarMovimiento()
    +registrarEmpuje()
    +registrarUndo()
    +getMovimientos() int
    +getEmpujes() int
    +getUsosUndo() int
    +reiniciar()
    +copia() Estadisticas
    +copiarDesde(Estadisticas otra)
  }

  class Celda {
    -Terreno terreno
    -ObjetoJuego objeto
    +getTerreno() Terreno
    +getObjeto() ObjetoJuego
    +setObjeto(ObjetoJuego o)
    +estaLibre() boolean
  }

  class Tablero {
    -Celda[][] celdas
    -int filas
    -int columnas
    -Jugador jugador
    +getFilas() int
    +getColumnas() int
    +getJugador() Jugador
    +getCelda(Posicion p) Celda
    +estaDentro(Posicion p) boolean
    +puedeMoverObjetoA(Posicion p) boolean
    +moverObjeto(Posicion origen, Posicion destino)
    +removerObjeto(ObjetoJuego o)
    +esVictoria() boolean
    +getCajas() List~Caja~
    +vincularCerrojos()
    +recalcularJugador()
  }

  class Juego {
    -Tablero tablero
    -List~String~ niveles
    -int indiceActual
    -Estadisticas stats
    -List~ObservadorJuego~ observadores
    -GestorUndo gestorUndo
    -EstrategiaPuntaje estrategia
    -CargadorNiveles cargador
    -FabricaElementos fabrica
    -EstadoJuego estadoJuego
    +getTablero() Tablero
    +getEstadisticas() Estadisticas
    +getNivelActual() int
    +hayNivelSiguiente() boolean
    +puedeDeshacer() boolean
    +isPausado() boolean
    +togglePausa()
    +getPuntaje() int
    +agregarObservador(ObservadorJuego o)
    +notificarEstadoInicial()
    +moverJugador(Direccion d)
    +crearMemento() MementoJuego
    +restaurar(MementoJuego m)
    +deshacer()
    +reiniciarNivel()
    +siguienteNivel()
    -notificar(EventoJuego e)
    -notificar(Tipo tipo)
    -intentarEmpujar(ObjetoJuego caja, Posicion pos, Direccion d) boolean
  }

  %% ============================================================
  %% OBSERVER
  %% ============================================================
  class ObservadorJuego {
    <<interface>>
    +actualizar(EventoJuego e)
  }

  class EventoJuego {
    -Tipo tipo
    -Tablero tablero
    -Estadisticas estadisticas
    -int nivelActual
    -boolean victoria
    -int puntaje
    +getTipo() Tipo
    +getTablero() Tablero
    +getEstadisticas() Estadisticas
    +getNivelActual() int
    +isVictoria() boolean
    +getPuntaje() int
  }

  class Tipo {
    <<enumeration>>
    INICIO
    MOVIMIENTO
    EMPUJE
    BLOQUEADO
    DESHACER
    REINICIO
    VICTORIA
    PAUSA
    REANUDA
  }

  %% ============================================================
  %% CRONOMETRO
  %% ============================================================
  class CronometroNivel {
    -Timer timer
    -int segundos
    -Consumer~Integer~ onTick
    +getSegundos() int
    +actualizar(EventoJuego e)
    -reiniciar()
  }

  %% ============================================================
  %% STATE — estado del juego
  %% ============================================================
  class EstadoJuego {
    <<interface>>
    +aceptaAcciones() boolean
  }
  class EstadoJugando {
    +aceptaAcciones() boolean
  }
  class EstadoPausado {
    +aceptaAcciones() boolean
  }

  %% ============================================================
  %% MEMENTO
  %% ============================================================
  class MementoJuego {
    -char[][] estadoTablero
    -Estadisticas estadoStats
    +getEstadoTablero() char[][]
    +getEstadoStats() Estadisticas
  }

  class GestorUndo {
    -int MAX_HISTORIAL$
    -int MAX_USOS_CONSECUTIVOS$
    -Deque~MementoJuego~ historial
    -int usosConsecutivos
    +guardar(MementoJuego m)
    +deshacer() MementoJuego
    +puedeDeshacer() boolean
    +limpiar()
  }

  %% ============================================================
  %% STRATEGY + DECORATOR
  %% ============================================================
  class EstrategiaPuntaje {
    <<interface>>
    +calcular(Estadisticas s) int
  }
  class PuntajeEstandar {
    -int BASE$
    +calcular(Estadisticas s) int
  }
  class PuntajeConTiempo {
    -int PENALIZACION_POR_SEGUNDO$
    -EstrategiaPuntaje base
    -CronometroNivel cronometro
    +calcular(Estadisticas s) int
  }

  %% ============================================================
  %% TERRENOS — Template Method
  %% ============================================================
  class Terreno {
    <<abstract>>
    +alEntrar(ObjetoJuego o, Tablero t)*
    +esDestino() boolean
    +getSimbolo() char*
  }
  class Piso {
    +alEntrar(ObjetoJuego o, Tablero t)
    +getSimbolo() char
  }
  class CasillaDestino {
    +esDestino() boolean
    +alEntrar(ObjetoJuego o, Tablero t)
    +getSimbolo() char
  }
  class TerrenoResbaladizo {
    +alEntrar(ObjetoJuego o, Tablero t)
    +getSimbolo() char
  }
  class CasilleroCerrojo {
    -List~Muro~ murosAsociados
    +setMurosAsociados(List~Muro~ muros)
    +getMurosAsociados() List~Muro~
    +alEntrar(ObjetoJuego o, Tablero t)
    +getSimbolo() char
  }

  %% ============================================================
  %% OBJETOS DEL JUEGO
  %% ============================================================
  class ObjetoJuego {
    <<abstract>>
    -Posicion posicion
    -Direccion ultimaDireccion
    +getPosicion() Posicion
    +setPosicion(Posicion p)
    +getUltimaDireccion() Direccion
    +setUltimaDireccion(Direccion d)
    +esEmpujable() boolean
    +bloqueaPaso() boolean
    +getSimbolo() char*
  }
  class Jugador {
    +getSimbolo() char
  }
  class Pared {
    +bloqueaPaso() boolean
    +getSimbolo() char
  }
  class Muro {
    -EstadoMuro estado
    +getEstado() EstadoMuro
    +setEstado(EstadoMuro e)
    +abrir()
    +bloqueaPaso() boolean
    +getSimbolo() char
  }

  %% ============================================================
  %% STATE — estado del Muro
  %% ============================================================
  class EstadoMuro {
    <<interface>>
    +puedeAtravesarse() boolean
  }
  class MuroCerrado {
    +puedeAtravesarse() boolean
  }
  class MuroAbierto {
    +puedeAtravesarse() boolean
  }

  %% ============================================================
  %% CAJAS
  %% ============================================================
  class Caja {
    <<abstract>>
    +esEmpujable() boolean
    +bloqueaPaso() boolean
    +alSerEmpujada(Tablero t)*
  }
  class CajaNormal {
    +alSerEmpujada(Tablero t)
    +getSimbolo() char
  }
  class CajaFragil {
    -int RESISTENCIA_INICIAL$
    -int resistencia
    +getResistencia() int
    +esEmpujable() boolean
    +alSerEmpujada(Tablero t)
    +getSimbolo() char
  }
  class CajaLlave {
    +alSerEmpujada(Tablero t)
    +getSimbolo() char
  }

  %% ============================================================
  %% FACTORY METHOD
  %% ============================================================
  class CreadorElemento {
    <<interface>>
    +crear(Posicion p) ElementoCreado
  }
  class ElementoCreado {
    -Terreno terreno
    -ObjetoJuego objeto
    +getTerreno() Terreno
    +getObjeto() ObjetoJuego
  }
  class FabricaElementos {
    -Map~Character,CreadorElemento~ charMap
    +crearElemento(char c, Posicion p) ElementoCreado
    +crearObjeto(char c, Posicion p) ObjetoJuego
  }
  class CargadorNiveles {
    -FabricaElementos fabrica
    +cargar(String archivoTxt) Tablero
  }

  %% ============================================================
  %% SINGLETON
  %% ============================================================
  class GestorAssets {
    <<Singleton>>
    -GestorAssets instancia$
    -Map~String,String~ rutas
    -Map~String,Image~ imagenes
    -Map~String,Clip~ sonidos
    +getInstancia() GestorAssets$
    +getImagen(String clave) Image
    +getSonido(String clave) Clip
  }
  class GestorSonido {
    <<Singleton>>
    -GestorSonido instancia$
    +getInstancia() GestorSonido$
    +actualizar(EventoJuego e)
  }

  %% ============================================================
  %% VISTA — MVC View
  %% ============================================================
  class VistaJuego {
    -PanelTablero panelTablero
    -PanelHUD panelHUD
    -boolean victoriaMostrada
    -ControladorJuego controlador
    -CronometroNivel cronometro
    +setCronometro(CronometroNivel c)
    +actualizarTiempo(int segundos)
    +inicializar(ControladorJuego c)
    +actualizar(EventoJuego e)
    -mostrarResumenYAvanzar(EventoJuego e)
  }
  class PanelTablero {
    -int CELDA$
    -Tablero tablero
    -boolean pausado
    +render(Tablero t)
    +setPausado(boolean pausado)
    #paintComponent(Graphics g)
    -dibujarTerreno(Graphics g, Terreno t, int x, int y)
    -dibujarMarcador(Graphics g, String clave, Color fallback, int x, int y)
    -dibujarObjeto(Graphics g, ObjetoJuego o, int x, int y)
    -dibujarJugador(Graphics g, Jugador j, int x, int y)
    -claveObjeto(ObjetoJuego o) String
    -dibujarObjetoPorDefecto(Graphics g, ObjetoJuego o, int x, int y)
    -dibujarCaja(Graphics g, int x, int y, Color color)
    -colorTerreno(Terreno t) Color
    -dibujarOverlayPausa(Graphics g)
  }
  class PanelHUD {
    -JLabel nivel
    -JLabel movimientos
    -JLabel empujes
    -JLabel tiempo
    -JButton btnUndo
    -JButton btnReiniciar
    -JButton btnPausa
    +conectar(ControladorJuego c)
    +actualizar(EventoJuego e)
    +actualizarTiempo(int segundos)
    -actualizarLabels(int nivelActual, int movs, int emp)
  }

  %% ============================================================
  %% CONTROLADOR — MVC Controller
  %% ============================================================
  class ControladorJuego {
    -Juego juego
    +keyPressed(KeyEvent e)
    +onUndo()
    +onReiniciar()
    +onTogglePausa()
    +onSiguienteNivel()
    +hayNivelSiguiente() boolean
  }

  %% ============================================================
  %% MAIN
  %% ============================================================
  class Main {
    -List~String~ NIVELES$
    +main(String[] args)$
    -iniciar(List~String~ niveles)$
  }

  %% ============================================================
  %% RELACIONES — herencias Swing
  %% ============================================================
  VistaJuego --|> JFrame
  PanelTablero --|> JPanel
  PanelHUD --|> JPanel
  ControladorJuego --|> KeyAdapter

  %% ============================================================
  %% RELACIONES — Observer
  %% ============================================================
  VistaJuego ..|> ObservadorJuego
  CronometroNivel ..|> ObservadorJuego
  GestorSonido ..|> ObservadorJuego
  Juego --> ObservadorJuego : notifica
  EventoJuego --> Tablero
  EventoJuego --> Estadisticas
  EventoJuego *-- Tipo

  %% ============================================================
  %% RELACIONES — State (juego)
  %% ============================================================
  EstadoJugando ..|> EstadoJuego
  EstadoPausado ..|> EstadoJuego
  Juego --> EstadoJuego

  %% ============================================================
  %% RELACIONES — Memento
  %% ============================================================
  Juego *-- GestorUndo
  GestorUndo o-- MementoJuego : max 15
  Juego ..> MementoJuego : crea/restaura

  %% ============================================================
  %% RELACIONES — Strategy + Decorator
  %% ============================================================
  PuntajeEstandar ..|> EstrategiaPuntaje
  PuntajeConTiempo ..|> EstrategiaPuntaje
  PuntajeConTiempo --> EstrategiaPuntaje : base
  PuntajeConTiempo --> CronometroNivel
  Juego --> EstrategiaPuntaje
  Juego *-- Estadisticas

  %% ============================================================
  %% RELACIONES — Factory
  %% ============================================================
  Juego --> CargadorNiveles
  Juego --> FabricaElementos
  CargadorNiveles --> FabricaElementos
  CargadorNiveles ..> Tablero : crea
  FabricaElementos --> CreadorElemento
  FabricaElementos ..> ElementoCreado : produce
  CreadorElemento ..> ElementoCreado : crea

  %% ============================================================
  %% RELACIONES — Tablero / Celda
  %% ============================================================
  Juego *-- Tablero
  Tablero *-- Celda
  Tablero --> Jugador
  Celda --> Terreno
  Celda --> ObjetoJuego

  %% ============================================================
  %% RELACIONES — Terrenos
  %% ============================================================
  Piso --|> Terreno
  CasillaDestino --|> Terreno
  TerrenoResbaladizo --|> Terreno
  CasilleroCerrojo --|> Terreno
  CasilleroCerrojo o-- Muro : murosAsociados

  %% ============================================================
  %% RELACIONES — Objetos
  %% ============================================================
  Jugador --|> ObjetoJuego
  Pared --|> ObjetoJuego
  Muro --|> ObjetoJuego
  Caja --|> ObjetoJuego
  CajaNormal --|> Caja
  CajaFragil --|> Caja
  CajaLlave --|> Caja
  ObjetoJuego --> Posicion
  ObjetoJuego --> Direccion

  %% ============================================================
  %% RELACIONES — State (Muro)
  %% ============================================================
  Muro --> EstadoMuro
  MuroCerrado ..|> EstadoMuro
  MuroAbierto ..|> EstadoMuro

  %% ============================================================
  %% RELACIONES — Singleton
  %% ============================================================
  GestorSonido --> GestorAssets
  PanelTablero ..> GestorAssets : sprites

  %% ============================================================
  %% RELACIONES — Vista / Controlador
  %% ============================================================
  VistaJuego *-- PanelTablero
  VistaJuego *-- PanelHUD
  VistaJuego --> ControladorJuego
  VistaJuego --> CronometroNivel
  ControladorJuego --> Juego

  %% ============================================================
  %% RELACIONES — Main
  %% ============================================================
  Main ..> Juego : crea
  Main ..> VistaJuego : crea
  Main ..> ControladorJuego : crea
  Main ..> CronometroNivel : crea
  Main ..> CargadorNiveles : crea
